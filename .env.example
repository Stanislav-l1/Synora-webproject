# ============================================================
# Synora — Environment Variables
# Copy this file to .env and replace all placeholder values
# ============================================================

# ── Database ──
DB_NAME=synora
DB_USER=synora
DB_PASSWORD=CHANGE_ME_db_password

# ── Redis ──
REDIS_PASSWORD=CHANGE_ME_redis_password

# ── MinIO (S3-compatible storage) ──
S3_ACCESS_KEY=CHANGE_ME_minio_access_key
S3_SECRET_KEY=CHANGE_ME_minio_secret_key
S3_BUCKET=synora-files
S3_REGION=us-east-1

# ── JWT (min 256-bit, base64-encoded) ──
# Generate with: openssl rand -base64 44
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_44

# ── Spring ──
SPRING_PROFILE=prod
LOG_LEVEL=INFO

# ── Ports (only nginx is exposed externally) ──
NGINX_PORT=80
