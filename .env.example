# ── Database ──
DB_NAME=synora
DB_USER=synora
DB_PASSWORD=synora_pass
DB_PORT=5432

# ── Redis ──
REDIS_PORT=6379
REDIS_PASSWORD=

# ── MinIO (S3) ──
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=synora-files
S3_REGION=us-east-1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── JWT ──
JWT_SECRET=changeme-in-production-use-256-bit-key

# ── Ports ──
BACKEND_PORT=8080
NGINX_PORT=80

# ── Spring ──
SPRING_PROFILE=default
